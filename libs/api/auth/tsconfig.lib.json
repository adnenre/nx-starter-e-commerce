{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../../dist/out-tsc",
    "tsBuildInfoFile": "../../../dist/tsconfig.lib.tsbuildinfo",

    "module": "esnext",
    "moduleResolution": "bundler",

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}
